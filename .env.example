# Copy this file to .env and fill in your values before running: npm run build
# .env is gitignored — these values get baked into the compiled bundle at build time

# Your self-hosted LibreTranslate server URL
XDL_LIBRE_URL=

# LibreTranslate API key (leave empty if your server has no auth)
XDL_LIBRE_KEY=

# Your self-hosted Whisper-compatible server URL
XDL_WHISPER_URL=


XDL_AUTH_TOKEN=""
XDL_CT0=""
