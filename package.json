{
  "name": "xdl",
  "version": "1.1.1",
  "description": "Download media from X (Twitter) with a stunning TUI",
  "type": "module",
  "bin": {
    "xdl": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.tsx",
    "build:bin": "bun build src/cli.tsx --compile --outfile build/xdl --target bun",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "clipboardy": "^5.3.1",
    "gradient-string": "^3.0.0",
    "ink": "^7.1.0",
    "meow": "^14.1.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "dotenv": "^17.4.2",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "twitter",
    "x",
    "video",
    "downloader",
    "cli",
    "tui",
    "batch",
    "gif",
    "hls",
    "watch"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akirco/xdl.git"
  },
  "homepage": "https://github.com/akirco/xdl#readme",
  "bugs": {
    "url": "https://github.com/akirco/xdl/issues"
  }
}